{
  "openapi": "3.0.4",
  "info": {
    "title": "SyncProject",
    "version": "1.0"
  },
  "paths": {
    "/ConfigurationSync/SetConfiguration": {
      "post": {
        "tags": [
          "ConfigurationSync"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SynchronizeDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SynchronizeDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SynchronizeDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/SynchronizeSync/Synchronization": {
      "post": {
        "tags": [
          "SynchronizeSync"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SynchronizeModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SynchronizeModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SynchronizeModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SynchronizeDto": {
        "type": "object",
        "properties": {
          "fileName": {
            "type": "string",
            "nullable": true
          },
          "configurationTableFile": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SynchronizeModel": {
        "type": "object",
        "properties": {
          "serverConnexionString": {
            "type": "string",
            "nullable": true
          },
          "localDb": {
            "type": "string",
            "nullable": true
          },
          "fileName": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "ConfigurationSync"
    },
    {
      "name": "SynchronizeSync"
    }
  ]
}